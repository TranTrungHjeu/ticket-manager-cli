{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",

    "strict": true,
    "esModuleInterop": true,

    "types": ["jest", "node"],

    "verbatimModuleSyntax": false,
    "isolatedModules": true,

    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "tests"]
}
